# Copy to `.env` in the repo root (gitignored). Used by `docker compose` when you run `make up` from the root.
#
# Weather / ETL database (SQLAlchemy URL). Default matches local Docker: Postgres service `db` on network `networkName`.
# For AWS RDS, set your endpoint and credentials here — never commit the real `.env`.
#
# WEATHER_DB_URL=postgresql+psycopg2://USER:PASSWORD@your-instance.region.rds.amazonaws.com:5432/weather
